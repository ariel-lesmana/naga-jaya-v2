generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brand {
  id           Int       @id @default(autoincrement())
  name         String    @unique @db.VarChar(255)
  source_sheet String?   @db.VarChar(100)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  products     Product[]

  @@map("brands")
}

model Product {
  id                Int      @id @default(autoincrement())
  brand_id          Int
  brand             Brand    @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  name              String   @db.VarChar(500)
  harga_per_karton  Int?
  harga_per_kotak   Int?
  harga_per_pak     Int?
  harga_per_lusin   Int?
  harga_per_pcs     Int?
  harga_net         Int?
  harga_daftar      Int?
  harga             Int?
  harga_jual        Int?
  harga_jual_per_lusin  Int?
  harga_jual_per_karton Int?
  harga_jual_per_kotak  Int?
  harga_jual_per_pak    Int?
  harga_gross       Int?
  disc_pct          Decimal?  @db.Decimal(5, 2)
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  deleted_at        DateTime? @db.Timestamp(6)
  price_history     PriceHistory[]
  receipt_items     ReceiptItem[]

  @@index([deleted_at])
  @@map("products")
}

model PriceHistory {
  id          Int      @id @default(autoincrement())
  product_id  Int
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  field       String   @db.VarChar(50)
  old_value   Int?
  new_value   Int?
  source      String   @db.VarChar(20)
  changed_by  String?  @db.VarChar(100)
  created_at  DateTime @default(now())

  @@index([product_id])
  @@index([created_at])
  @@map("price_history")
}

enum ReceiptStatus {
  DRAFT
  FINALIZED
}

enum ReceiptUnit {
  pcs
  lusin
  pak
  kotak
  karton
}

model Receipt {
  id            Int           @id @default(autoincrement())
  customer_name String?       @db.VarChar(255)
  status        ReceiptStatus @default(DRAFT)
  finalized_at  DateTime?     @db.Timestamp(6)
  created_at    DateTime      @default(now()) @db.Timestamp(6)
  updated_at    DateTime      @updatedAt @db.Timestamp(6)
  deleted_at    DateTime?     @db.Timestamp(6)
  items         ReceiptItem[]

  @@index([status])
  @@index([deleted_at])
  @@index([created_at])
  @@map("receipts")
}

model ReceiptItem {
  id                    Int          @id @default(autoincrement())
  receipt_id            Int
  receipt               Receipt      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  product_id            Int?
  product               Product?     @relation(fields: [product_id], references: [id], onDelete: SetNull)
  product_name_snapshot String?      @db.VarChar(500)
  quantity              Int?
  unit_type             ReceiptUnit?
  price_snapshot        Int?
  discount_per_unit     Int?         @default(0)
  line_total_override   Int?
  notes                 String?      @db.VarChar(500)
  position              Int          @default(0)
  created_at            DateTime     @default(now()) @db.Timestamp(6)
  updated_at            DateTime     @updatedAt @db.Timestamp(6)

  @@index([receipt_id])
  @@map("receipt_items")
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  method        String   @db.VarChar(10)
  path          String   @db.VarChar(500)
  query         Json?
  status_code   Int
  duration_ms   Int
  request_body  Json?
  response_body Json?
  error_message String?
  ip            String?  @db.VarChar(45)
  user_agent    String?  @db.VarChar(500)
  created_at    DateTime @default(now())

  @@index([created_at])
  @@index([method])
  @@index([path])
  @@map("audit_logs")
}
